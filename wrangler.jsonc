{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "brookfield-digital",
  "main": "src/worker.ts",
  "compatibility_date": "2025-09-27",
  "account_id": "50e564a0884c74905e9312d0f9506c2a",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "none",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "AWS_SES_REGION": "us-east-1"
  }
}

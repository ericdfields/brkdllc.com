---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import ProjectFeature from '../components/ProjectFeature.astro';
---

<Base title="Brookfield Digital">

  <!-- 0. Studio Hero -->
  <Section id="studio" theme="studio">
    <div class="studio-hero">
      <p class="studio-eyebrow">Brookfield Digital</p>
      <h1 class="studio-headline">
        We build software for people doing real work.
      </h1>
      <p class="studio-sub">
        A small studio out of Baltimore, MD. Three products live in the wild —
        scroll to meet them.
      </p>
      <nav class="studio-chips" aria-label="Products">
        <a href="#picket" class="chip">Picket</a>
        <a href="#ridgeline" class="chip">Ridgeline</a>
        <a href="#argus" class="chip">Argus</a>
      </nav>
    </div>
  </Section>

  <!-- 1. Picket -->
  <Section id="picket" theme="picket">
    <ProjectFeature
      name="Picket"
      tagline="The online storefront built for growers, not retailers."
      description="Subscriptions, delivery routes, and seasonal inventory — for flower farms, CSAs, market gardens, and home bakers. Starting at $0/mo."
      url="https://sellwithpicket.com"
      logo="/images/picket/logo.svg"
      logoAlt="Picket"
      screenshots={['/images/picket/storefront.png', '/images/picket/orders.png']}
      screenshotAlts={['Picket storefront dashboard', 'Picket order management']}
    />
  </Section>

  <!-- 2. Ridgeline -->
  <Section id="ridgeline" theme="ridgeline">
    <ProjectFeature
      name="Ridgeline"
      tagline="Technical due diligence for wind acquisitions."
      description="You're under LOI. The exclusivity window is ticking. Ridgeline runs structured technical assessment across every turbine in the deal — so you close with confidence."
      url="https://ridgelineasset.com"
      logo="/images/ridgeline/logo.svg"
      logoAlt="Ridgeline"
      screenshots={['/images/ridgeline/risk-heatmap.png', '/images/ridgeline/site-detail.png']}
      screenshotAlts={['Ridgeline risk scoring dashboard', 'Ridgeline site detail view']}
    />
  </Section>

  <!-- 3. Argus -->
  <Section id="argus" theme="argus">
    <ProjectFeature
      name="Argus"
      tagline="Every image you upload, understood."
      description="AI-powered media catalog. Upload via dashboard, CLI, API, or MCP. Extracts descriptions, tags, mood, and palette. Built for teams and agents."
      url="https://argus.build"
      logo="/images/argus/logo.svg"
      logoAlt="Argus"
      screenshots={['/images/argus/catalog.png', '/images/argus/detail.png']}
      screenshotAlts={['Argus media catalog', 'Argus image analysis detail']}
    />
  </Section>

  <!-- 4. How We Work + Contact -->
  <Section id="work" theme="work">
    <div class="work-grid">
      <div class="work-process">
        <h2 class="work-heading">How we work</h2>
        <ol class="work-steps">
          <li class="work-step">
            <span class="work-step-num">01</span>
            <div>
              <h3 class="work-step-title">Discovery</h3>
              <p class="work-step-desc">We learn your business, map workflows, and identify the highest-leverage opportunity for software.</p>
            </div>
          </li>
          <li class="work-step">
            <span class="work-step-num">02</span>
            <div>
              <h3 class="work-step-title">Build</h3>
              <p class="work-step-desc">Small team, fast cycles. You see working software every week — not decks and wireframes.</p>
            </div>
          </li>
          <li class="work-step">
            <span class="work-step-num">03</span>
            <div>
              <h3 class="work-step-title">Ship &amp; Support</h3>
              <p class="work-step-desc">We launch, monitor, and iterate. Your product gets better after launch, not before.</p>
            </div>
          </li>
        </ol>
      </div>
      <div class="work-contact">
        <h2 class="work-heading">Get in touch</h2>
        <p class="work-contact-email">
          <a href="mailto:eric@brkdllc.com">eric@brkdllc.com</a>
        </p>
        <form class="work-form" data-static="true">
          <label class="work-label">
            <span>Name</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label class="work-label">
            <span>Email</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
          <label class="work-label">
            <span>Message</span>
            <textarea name="message" rows="4" required></textarea>
          </label>
          <button type="submit" class="work-submit">Send message</button>
        </form>
      </div>
    </div>
  </Section>

  <!-- 5. Footer -->
  <Section id="contact" theme="footer">
    <footer class="site-footer">
      <p class="footer-brand">Brookfield Digital</p>
      <p class="footer-tagline">
        Building tools for the people big platforms overlook.
      </p>
      <nav class="footer-links" aria-label="Product links">
        <a href="https://sellwithpicket.com" target="_blank" rel="noopener">Picket</a>
        <a href="https://ridgelineasset.com" target="_blank" rel="noopener">Ridgeline</a>
        <a href="https://argus.build" target="_blank" rel="noopener">Argus</a>
      </nav>
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} Brookfield Digital, LLC &middot; Baltimore, MD
      </p>
    </footer>
  </Section>

</Base>

<style>
  .studio-hero {
    max-width: 780px;
    margin: 0 auto;
  }

  .studio-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .studio-headline {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .studio-sub {
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 50ch;
    margin-bottom: 3rem;
  }

  .studio-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .chip {
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background 0.2s, color 0.2s;
  }

  .chip:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .site-footer {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-brand {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .footer-tagline {
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 2.5rem;
    max-width: 40ch;
    margin-inline: auto;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .footer-links a {
    color: var(--color-text);
    font-weight: 500;
    font-size: 1rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  /* How We Work + Contact */
  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  @media (min-width: 900px) {
    .work-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
  }

  .work-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 2rem;
  }

  .work-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .work-step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .work-step-num {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-muted);
    letter-spacing: 0.05em;
    padding-top: 0.15rem;
    flex-shrink: 0;
  }

  .work-step-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  .work-step-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
    max-width: 40ch;
    line-height: 1.5;
  }

  .work-contact-email {
    margin-bottom: 2rem;
  }

  .work-contact-email a {
    color: var(--color-accent);
    font-size: 1rem;
    font-weight: 500;
  }

  .work-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .work-label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .work-label span {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .work-label input,
  .work-label textarea {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 6px;
    padding: 0.7rem 0.9rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }

  .work-label input:focus,
  .work-label textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .work-label textarea {
    resize: vertical;
  }

  .work-submit {
    align-self: flex-start;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 600;
    font-size: 0.95rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .work-submit:hover {
    opacity: 0.85;
  }
</style>
